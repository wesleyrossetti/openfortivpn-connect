{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenFortiVpn Connect",
  "version": "0.1.7",
  "identifier": "com.openfortivpn-connect.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OPENFORTIVPN CONNECT",
        "hiddenTitle": true,
        "width": 400,
        "height": 560,
        "resizable": false,
        "fullscreen": false,
        "visible": true,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/lib/openfortivpn-connect/openfortivpn": "openfortivpn/openfortivpn",
          "/usr/lib/openfortivpn-connect/openvpngui-helper": "target/release/openvpngui-helper"
        }
      },
      "rpm": {
        "files": {
          "/usr/lib/openfortivpn-connect/openfortivpn": "openfortivpn/openfortivpn",
          "/usr/lib/openfortivpn-connect/openvpngui-helper": "target/release/openvpngui-helper"
        }
      }
    }
  }
}
